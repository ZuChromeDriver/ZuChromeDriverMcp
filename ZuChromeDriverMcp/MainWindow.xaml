<Window x:Class="ZuChromeDriverMcp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ZuChromeDriverMcp.Views"
        Title="ZuChromeDriver MCP" Height="720" Width="1024"
        MinHeight="500" MinWidth="800">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
        </StatusBar>

        <TabControl Margin="8">
            <TabItem Header="Настройки">
                <views:SettingsView DataContext="{Binding Settings}" />
            </TabItem>
            <TabItem Header="Профили">
                <views:ProfilesView DataContext="{Binding Profiles}" />
            </TabItem>
            <TabItem Header="Управление">
                <views:ControlView DataContext="{Binding Control}" />
            </TabItem>
            <TabItem Header="Рантайм">
                <views:RuntimeView DataContext="{Binding Runtime}" />
            </TabItem>
            <TabItem Header="MCP">
                <views:McpInfoView DataContext="{Binding McpInfo}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
