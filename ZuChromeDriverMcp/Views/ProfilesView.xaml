<UserControl x:Class="ZuChromeDriverMcp.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12" MaxWidth="960">
            <TextBlock Text="Chrome profiles" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="{Binding ProfilesRoot}" Foreground="Gray" Margin="0,0,0,12" TextWrapping="Wrap" />

            <DataGrid ItemsSource="{Binding Profiles}"
                      SelectedItem="{Binding SelectedProfile}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      MinHeight="180"
                      Margin="0,0,0,12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="120" />
                    <DataGridTextColumn Header="Тип" Binding="{Binding KindDisplay}" Width="140" />
                    <DataGridTextColumn Header="Путь" Binding="{Binding PathDisplay}" Width="*" />
                    <DataGridCheckBoxColumn Header="Выбран"
                                            Binding="{Binding IsSelected, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Width="70" />
                </DataGrid.Columns>
            </DataGrid>

            <WrapPanel Margin="0,0,0,16">
                <Button Content="Применить выбранный" Command="{Binding ApplySelectedProfileCommand}" Padding="12,6" Margin="0,0,8,8" />
                <Button Content="Обновить" Command="{Binding RefreshProfilesCommand}" Padding="12,6" Margin="0,0,8,8" />
                <Button Content="Удалить" Command="{Binding RemoveSelectedProfileCommand}" Padding="12,6" Margin="0,0,8,8" />
            </WrapPanel>

            <TextBlock Text="Добавить профиль в Profiles/" FontWeight="SemiBold" Margin="0,0,0,8" />
            <UniformGrid Columns="2" Margin="0,0,0,8">
                <TextBlock Text="Имя папки / профиля" VerticalAlignment="Center" />
                <TextBox Text="{Binding NewFolderProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
            </UniformGrid>
            <Button Content="Добавить папочный профиль" Command="{Binding AddFolderProfileCommand}" HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,16" />

            <TextBlock Text="Добавить профиль с произвольным путём" FontWeight="SemiBold" Margin="0,0,0,8" />
            <UniformGrid Columns="2" Margin="0,0,0,8">
                <TextBlock Text="Имя профиля" VerticalAlignment="Center" />
                <TextBox Text="{Binding NewCustomProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <TextBlock Text="Путь user-data-dir" VerticalAlignment="Center" />
                <DockPanel Margin="0,2">
                    <Button Content="Обзор..." Command="{Binding BrowseCustomPathCommand}" DockPanel.Dock="Right" Padding="10,4" Margin="8,0,0,0" />
                    <TextBox Text="{Binding NewCustomPath, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
            </UniformGrid>
            <Button Content="Добавить произвольный профиль" Command="{Binding AddCustomProfileCommand}" HorizontalAlignment="Left" Padding="12,6" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
