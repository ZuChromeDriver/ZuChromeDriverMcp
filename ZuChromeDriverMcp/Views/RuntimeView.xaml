<UserControl x:Class="ZuChromeDriverMcp.Views.RuntimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <WrapPanel Margin="0,0,0,8">
                <TextBlock Text="Status:" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToConnectedText}}" Margin="0,0,16,0" />
                <TextBlock Text="Chrome port:" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding ChromePort}" Margin="0,0,16,0" />
                <TextBlock Text="Network:" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding NetworkCount}" Margin="0,0,16,0" />
                <TextBlock Text="Console:" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding ConsoleCount}" />
            </WrapPanel>
            <TextBlock Text="{Binding ActivePageUrl, StringFormat=Active page: {0}}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <TextBlock Text="{Binding LastError, StringFormat=Last error: {0}}" TextWrapping="Wrap" Foreground="DarkRed" Margin="0,0,0,4" />
            <WrapPanel Margin="0,0,0,8">
                <TextBlock Text="{Binding LastArtifactPath, StringFormat=Last artifact: {0}}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Button Content="Open folder" Command="{Binding OpenLastArtifactFolderCommand}" Padding="8,4" VerticalAlignment="Center" />
            </WrapPanel>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" HorizontalAlignment="Left" Padding="12,6" />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock DockPanel.Dock="Top" Text="Console (recent)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ListBox ItemsSource="{Binding RecentConsole}" />
            </DockPanel>
            <DockPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="Network (recent)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ListBox ItemsSource="{Binding RecentNetwork}" />
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
