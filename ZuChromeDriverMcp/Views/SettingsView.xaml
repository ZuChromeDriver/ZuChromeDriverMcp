<UserControl x:Class="ZuChromeDriverMcp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12" MaxWidth="900">
            <TextBlock Text="Chrome" FontWeight="SemiBold" Margin="0,0,0,8" />
            <UniformGrid Columns="2" Margin="0,0,0,12">
                <TextBlock Text="Port" VerticalAlignment="Center" />
                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <TextBlock Text="Window width" VerticalAlignment="Center" />
                <TextBox Text="{Binding WindowWidth, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <TextBlock Text="Window height" VerticalAlignment="Center" />
                <TextBox Text="{Binding WindowHeight, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <TextBlock Text="Chrome args" VerticalAlignment="Center" />
                <TextBox Text="{Binding CommandLineArguments, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <TextBlock Text="MCP HTTP port" VerticalAlignment="Center" />
                <TextBox Text="{Binding McpHttpPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
                <TextBlock Text="MCP HTTP path" VerticalAlignment="Center" />
                <TextBox Text="{Binding McpHttpPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" />
            </UniformGrid>

            <WrapPanel Margin="0,0,0,4">
                <CheckBox Content="Headless" IsChecked="{Binding Headless}" Margin="0,0,16,8" />
                <CheckBox Content="Attach only" IsChecked="{Binding AttachOnly}" Margin="0,0,16,8" />
                <CheckBox Content="Connect on startup" IsChecked="{Binding ConnectChromeOnStartup}" Margin="0,0,16,8" />
            </WrapPanel>

            <TextBlock Text="Browser behavior" FontWeight="SemiBold" Margin="0,8,0,8" />
            <WrapPanel Margin="0,0,0,12">
                <CheckBox Content="Frame tracker" IsChecked="{Binding EnableFrameTrackerOnConnect}" Margin="0,0,16,8" />
                <CheckBox Content="DOM tracker" IsChecked="{Binding EnableDomTrackerOnConnect}" Margin="0,0,16,8" />
                <CheckBox Content="Browser log capture" IsChecked="{Binding EnableBrowserLogCaptureOnConnect}" Margin="0,0,16,8" />
                <CheckBox Content="Network (CDP)" IsChecked="{Binding EnableNetworkCaptureOnConnect}" Margin="0,0,16,8" />
                <CheckBox Content="Console (CDP)" IsChecked="{Binding EnableConsoleCaptureOnConnect}" Margin="0,0,16,8" />
            </WrapPanel>

            <TextBlock Text="MCP tools" FontWeight="SemiBold" Margin="0,0,0,8" />
            <WrapPanel Margin="0,0,0,12">
                <CheckBox Content="Network requests" IsChecked="{Binding EnableListNetworkRequestsTool}" Margin="0,0,16,8" />
                <CheckBox Content="Console messages" IsChecked="{Binding EnableListConsoleMessagesTool}" Margin="0,0,16,8" />
                <CheckBox Content="Evaluate" IsChecked="{Binding EnableEvaluateTool}" Margin="0,0,16,8" />
                <CheckBox Content="Screenshot" IsChecked="{Binding EnableScreenshotTool}" Margin="0,0,16,8" />
                <CheckBox Content="Snapshot" IsChecked="{Binding EnableTakeSnapshotTool}" Margin="0,0,16,8" />
                <CheckBox Content="Input" IsChecked="{Binding CategoryInput}" Margin="0,0,16,8" />
                <CheckBox Content="Navigation" IsChecked="{Binding CategoryNavigation}" Margin="0,0,16,8" />
                <CheckBox Content="Memory" IsChecked="{Binding CategoryMemory}" Margin="0,0,16,8" />
            </WrapPanel>

            <Button Content="Применить настройки" Command="{Binding ApplySettingsCommand}" HorizontalAlignment="Left" Padding="12,6" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
